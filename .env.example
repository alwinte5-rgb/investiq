# InvestIQ environment template. Copy to .env (never commit real secrets).
# Secrets are SERVER-ONLY. Never put a secret in a NEXT_PUBLIC_ / EXPO_PUBLIC_ var.
#
# Only the REQUIRED block is needed to boot. Everything below it is OPTIONAL —
# features light up as you add keys; the app degrades gracefully without them.

NODE_ENV=development

# ============================================================
# REQUIRED TO BOOT
# ============================================================
# Postgres (Railway provides this automatically as DATABASE_URL)
DATABASE_URL=postgresql://user:pass@localhost:5432/investiq

# Clerk auth — dashboard.clerk.com -> API keys (pick "Next.js" to see these names)
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...              # created when you add the Clerk webhook
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_... # publishable (non-secret) — safe for client
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_... # same value as above (mobile)

# Allowed CORS origins (comma-separated; no wildcard with credentials)
ALLOWED_ORIGINS=http://localhost:3000

# Port: Railway sets PORT automatically. Locally the API uses API_PORT.
# PORT=4000
API_PORT=4000

# ============================================================
# OPTIONAL — Layer 1 features (recommended to make quotes + news real)
# ============================================================
# Market data. Twelve Data is PRIMARY (free key at twelvedata.com).
TWELVEDATA_API_KEY=
# Massive (formerly Polygon.io) — FALLBACK. Base URL is configurable.
MASSIVE_API_KEY=
MASSIVE_BASE_URL=https://api.polygon.io

# News (free tiers): MarketAux is enough on its own; Benzinga is paid.
MARKETAUX_API_KEY=
BENZINGA_API_KEY=

# ============================================================
# OPTIONAL — later layers (leave blank until that layer is built)
# ============================================================
# AI (Layer 2)
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8

# Brokerage connect (SnapTrade, Layer 1 #7)
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=
# Encrypts stored SnapTrade secrets (generate: openssl rand -hex 24). 32+ chars.
CONNECTION_ENCRYPTION_KEY=

# Paper trading (Alpaca, Layer 9)
ALPACA_PAPER_KEY_ID=
ALPACA_PAPER_SECRET=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets

# Fundamentals / economic (Layer 2/5)
FMP_API_KEY=

# Storage (Supabase)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=investiq

# Email (Resend, Layer 4)
RESEND_API_KEY=
EMAIL_FROM=noreply@investiq.app

# Cache/queues (in-memory used until provided)
REDIS_URL=

# Push notifications
EXPO_ACCESS_TOKEN=
