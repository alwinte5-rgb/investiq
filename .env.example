# InvestIQ environment template. Copy to .env (never commit real secrets).
# Secrets are SERVER-ONLY. Never put a secret in a NEXT_PUBLIC_ / EXPO_PUBLIC_ var.

NODE_ENV=development

# --- Database (Railway Postgres) ---
DATABASE_URL=postgresql://user:pass@localhost:5432/investiq

# --- Redis (cache, queues, rate limiting) ---
REDIS_URL=redis://localhost:6379

# --- Auth: Clerk ---
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=   # publishable (non-secret) — safe for client
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=   # publishable (non-secret) — safe for client

# --- AI: Claude ---
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8

# --- Brokerage: SnapTrade (read-only) ---
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=
# Key used to encrypt stored SnapTrade user secrets at rest:
CONNECTION_ENCRYPTION_KEY=

# --- Paper trading: Alpaca (paper only, no live) ---
ALPACA_PAPER_KEY_ID=
ALPACA_PAPER_SECRET=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets

# --- Market data ---
POLYGON_API_KEY=
TWELVEDATA_API_KEY=        # fallback

# --- News ---
BENZINGA_API_KEY=
MARKETAUX_API_KEY=

# --- Fundamentals / economic ---
FMP_API_KEY=

# --- Storage: Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY= # server-only
SUPABASE_STORAGE_BUCKET=investiq

# --- Email: Resend ---
RESEND_API_KEY=
EMAIL_FROM=noreply@investiq.app

# --- Push notifications ---
EXPO_ACCESS_TOKEN=

# --- App config ---
API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000
WEB_ORIGIN=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000   # comma-separated allowlist (no wildcard w/ credentials)
API_PORT=4000
